{
  "name": "hms-portal",
  "version": "1.0.0",
  "description": "Hospital Management System — Desktop",
  "main": "electron/main.js",
  "scripts": {
    "dev":        "vite",
    "build":      "vite build",
    "preview":    "vite preview",
    "electron:dev":   "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:pack":  "npm run build && electron-builder --dir"
  },
  "build": {
    "appId": "com.hms.portal",
    "productName": "HMS Portal",
    "copyright": "HMS Medical Centre",
    "directories": {
      "buildResources": "electron",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/main.js",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "HMS-backend",
        "to": "HMS-backend",
        "filter": [
          "**/*",
          "!node_modules/.cache/**",
          "!**/*.log"
        ]
      }
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Office",
      "icon": "electron/icon.png"
    },
    "win": {
      "target": ["nsis"],
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/icon.ico",
      "shortcutName": "HMS Portal"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^8.0.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "lucide-react": "^0.383.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
